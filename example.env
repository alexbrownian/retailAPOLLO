# Copy this file to `.env` (project root) and fill in what you have.
# `.env` is git-ignored - real credentials never reach a commit.
# Full documentation of every key: docs/LIVE_INGESTION.md
# Check what will be called without spending anything:
#   python ingestion/fetch_all.py --check

# --- FetchLayer (third-party X/Reddit data API, fetchlayer.dev) ---
# Powers the X (Twitter) fetcher; 1 credit per request.
# The Reddit default (Arctic Shift) and StockTwits need NO key.
FETCHLAYER_KEY= ss-18233eb2ed288e1aff01d0e2f46fb24fa00d9965f03c42160b6fc8acc0fd

# --- Reddit official API (only for the manual FetchLayer fallback) ---
REDDIT_APP_NAME=
REDDIT_PERSONAL_USE=

REDDIT_SECRET=
REDDIT_USERNAME=
REDDIT_PASSWORD=

# --- X / Twitter official v2 API (paid; empty = FetchLayer is used) ---
X_BEARER_TOKEN=
